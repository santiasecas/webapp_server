      "display_name": "Administrator",
      "active": true
    },
    "alice": {
      "password_hash": "$2y$12$REPLACE_WITH_REAL_HASH_USE_manage_users_script",
      "groups": ["users"],
      "display_name": "Alice",
      "active": true
    },
    "viewer": {
      "password_hash": "$2y$12$REPLACE_WITH_REAL_HASH_USE_manage_users_script",
      "groups": ["viewers"],
