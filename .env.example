# ═══════════════════════════════════════════════════════════════
#  Corporate Platform — Environment Configuration
#  Copy to .env and fill in your values. Never commit .env.
# ═══════════════════════════════════════════════════════════════

# ── App ──────────────────────────────────────────────────────────
APP_TITLE=Corporate Platform
APP_DESCRIPTION=Internal webapp platform
APP_VERSION=1.0.0
ENVIRONMENT=development    # development | staging | production
DEBUG=true                 # Set false in production

# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE-ME-generate-a-real-secret-key-here

# ── Server ───────────────────────────────────────────────────────
HOST=127.0.0.1
PORT=8000
WORKERS=1

# ── Database ─────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=corporate_platform
DB_USER=platform_user
DB_PASSWORD=your_db_password_here
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_ECHO=false

# ── Authentication & Sessions ─────────────────────────────────────
# Users file (JSON with groups). Managed via scripts/manage_users.py
USERS_FILE=.users.json

# Session cookie lifetime in seconds (default: 8 hours)
SESSION_MAX_AGE=28800

# Set true when the app is served over HTTPS
SESSION_COOKIE_SECURE=false

# ── Logging ──────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=                  # Leave empty for stdout only
